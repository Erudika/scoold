<div class="page-wrapper">
	<div class="row">
		<div class="col s12 m8 offset-m2 l6 offset-l3">
			<div class="center em3v">
				<svg xmlns="http://www.w3.org/2000/svg" version="1.1" id="svg2" width="266px" viewBox="0 80.5 1465 400" aria-label="Scoold logo" class="responsive-img mbm" xmlns:bx="https://boxy-svg.com"><defs id="defs6"><bx:export><bx:file format="svg"/></bx:export></defs><g id="g10" transform="matrix(1.293756, 0, 0, -1.293756, 10.502501, 633.943484)" style=""><g id="g12" transform="scale(0.1)" style="fill:#03a9f4;fill-opacity:1"><g id="g4515" transform="translate(207.08505,1265.7305)"><path id="path26" style="fill:#03a9f4;fill-opacity:1;fill-rule:nonzero;stroke:none" d="m 675.883,830 h 250 v 870 h -250 z"/><path id="path28" style="fill:#03a9f4;fill-opacity:1;fill-rule:nonzero;stroke:none" d="m 2929.06,654.859 c -335.29,0 -608.05,272.77 -608.05,608.051 0,335.28 272.76,608.05 608.05,608.05 335.28,0 608.04,-272.77 608.04,-608.05 0,-335.281 -272.76,-608.051 -608.04,-608.051 z m -2117.29,0 c -335.286,0 -608.047,272.77 -608.047,608.051 0,335.28 272.761,608.05 608.047,608.05 335.28,0 608.04,-272.77 608.04,-608.05 0,-335.281 -272.76,-608.051 -608.04,-608.051 z M 2929.06,2059.68 c -406.46,0 -742.57,-305.99 -790.64,-699.68 h -536.01 c -48.07,393.69 -384.18,699.68 -790.64,699.68 C 372.426,2059.68 15,1702.26 15,1262.91 15,823.57 372.426,466.141 811.77,466.141 c 407.9,0 744.99,308.168 791.17,703.859 h 534.95 c 46.18,-395.691 383.27,-703.859 791.17,-703.859 439.34,0 796.77,357.429 796.77,796.769 0,439.35 -357.43,796.77 -796.77,796.77"/><path id="path30" style="fill:#03a9f4;fill-opacity:1;fill-rule:nonzero;stroke:none" d="m 2914.06,1077.7 c -102.13,0 -185.22,83.08 -185.22,185.21 0,102.13 83.09,185.22 185.22,185.22 102.13,0 185.21,-83.09 185.21,-185.22 0,-102.13 -83.08,-185.21 -185.21,-185.21 z m 0,622.06 c -240.88,0 -436.85,-195.98 -436.85,-436.85 0,-240.88 195.97,-436.84 436.85,-436.84 240.88,0 436.84,195.96 436.84,436.84 0,240.87 -195.96,436.85 -436.84,436.85"/></g></g></g><path d="M 657.514 388.5 Q 638.065 388.5 626.144 385.049 Q 614.223 381.598 609.518 379.402 L 614.851 360.58 Q 619.243