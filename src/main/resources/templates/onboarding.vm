07 381.912 1399.823 383.951 Q 1391.04 385.99 1380.06 387.245 Q 1369.081 388.5 1355.592 388.5 Z M 1356.533 369.364 Q 1369.708 369.364 1378.962 367.952 Q 1388.216 366.541 1393.549 364.972 L 1393.549 252.668 Q 1387.275 247.648 1376.139 243.1 Q 1365.003 238.551 1351.2 238.551 Q 1337.083 238.551 1326.888 243.413 Q 1316.693 248.276 1310.419 257.216 Q 1304.145 266.157 1301.165 278.077 Q 1298.185 289.998 1298.185 303.801 Q 1298.185 324.505 1305.4 339.092 Q 1312.615 353.679 1325.633 361.521 Q 1338.652 369.364 1356.533 369.364 Z" id="scoold" fill="#404040"/>
				<style>[data-theme="dark"] #scoold {fill: #FFFFFF;}</style>
				</svg>
			</div>
			<div class="onboarding-progress em3v">
				#foreach ($s in [1..$totalSteps])
					<div class="progress-step #if($step == $s)active#elseif($step > $s)complete#end">
						<a href="$onboardinglink/$s" class="progress-circle">$s</a>
						#if($s < $totalSteps)<div class="progress-line"></div>#end
					</div>
				#end
			</div>
			<div class="logo-bg">
				<div class="inset-gradient"></div>
			</div>

			#if ($step == 1)
			<div class="card-panel mvl">
				<div class="card z-depth-0 pal mtl">
					<h3 class="center">$!lang.get("onboarding.title")</h3>
					<p class="center">$!lang.get("onboarding.step1.desc")</p>

					<form method="post" action="$onboardinglink/language" id="onboarding-language-form">
						<div class="row">
							<div class="col s10 m8 offset-m2 l6 offset-l3 offset-s1">
								<div class="input-field mtl">
									<select name="locale" id="locale-select">
										#foreach ($locale in $availableLocales)
											<option value="$locale.language" #if($locale.language == 'en')selected#end>$!locale.getDisplayName($!locale)</option>
										#end
									</select>
									<label>$!lang.get("translate.select")</label>
								</div>
							</div>
						</div>
						<div class="center pvl">
							<button class="lightborder btn-flat waves-effect waves-light" type="submit">
								$!lang.get('next') &rarr;
							</button>
						</div>
					</form>
				</div>
			</div>
			#end
			#if ($step == 2)
			<div class="card-panel mvl">
				<div class="row">
					<div class="col s12 m8 offset-m2 l8 offset-l2">
						<h3 class="center">$!lang.get("onboarding.backend")</h3>

						<ul class="collapsible z-depth-0 mtl">
							<li>
								<div class="collapsible-header">
										#icon('<path d="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" />' 'mhs')
										$!lang.get("onboarding.copyconfig")
								</div>
								<div class="collapsible-body">
									<div class="input-field">
										<label for="raw-config">$!lang.get("onboarding.rawconfig")</label>
										<textarea id="raw-config" name="rawConfig" class="materialize-textarea monospace" placeholder="scoold.host_url = ..."></textarea>
									</div>
									<p class="small">
											$!lang.get("onboarding.rawconfig.hint")
									</p>
								</div>
							</li>
						</ul>

						<p class="center pvl">$!lang.get("onboarding.backend.hint")</p>
						<form method="post" action="$onboardinglink/para-setup" id="onboarding-para-form">
							<div class="input-field mtl">
								<label for="para-endpoint">$!lang.get("onboarding.para.endpoint")</label>
								<input type="url" id="para-endpoint" name="paraEndpoint" value="$!paraEndpoint" class="validate" required>
							</div>
							<div class="input-field mtm">
								<label for="para-access-key">$!lang.get("onboarding.para.accesskey")</label>
								<input type="text" id="para-access-key" name="paraAccessKey" value="$!paraAccessKey" class="validate" required>
							</div>
							<div class="input-field mtm">
								<label for="para-secret-key">$!lang.get("onboarding.para.secretkey")</label>
								<input type="password" id="para-secret-key" name="paraSecretKey" value="$!paraSecretKey" class="validate" required>
							</div>
							<div class="center mtl">
								<button type="button" id="test-para-btn" class="btn-flat waves-effect" data-url="$onboardinglink/test-para-connection">
									$!lang.get("onboarding.testconnection")
								</button>
								<div id="para-test-result" class="mtm">&nbsp;
									#if ($isConnectedToPara)
										<span class="green-text text-darken-3 center mvl pvl">
											#ico("check-circle" "") $!lang.get("onboarding.para.connected")
										</span>
									#end
								</div>
							</div>

							<div class="center pvl">
								<button class="lightborder btn-flat waves-effect waves-light" type="submit">
									$!lang.get('next') &rarr;
								</button>
							</div>
						</form>
					</div>
				</div>
			</div>
			#end
			#if ($step == 3)
			<div class="card-panel mvl">
				<div class="row">
					<div class="col s12 m10 offset-m1 l10 offset-l1">
						<h3 class="center">$!lang.get("onboarding.sitesetup")</h3>
						<p class="center">$!lang.get("onboarding.sitesetup.hint")</p>

						<form method="post" action="$onboardinglink/site-setup" id="onboarding-site-form">
							<div class="card z-depth-0 pal mtl">
								<div class="input-field mtm">
									<label for="app-name">$!lang.get("onboarding.sitename", "Site Name")</label>
									<input type="text" id="app-name" name="appName" value="$!appName" maxlength="255">
								</div>
								<div class="input-field mtm">
									<label for="host-url">$!lang.get("onboarding.siteurl")</label>
									<input type="url" id="host-url" name="hostUrl" value="$!hostUrl" placeholder="https://">
									<span>$!lang.get("onboarding.siteurl.hint")</span>
								</div>
								<p class="mtm">
									<label>
										<input type="checkbox" name="isDefaultSpacePublic" class="filled-in" #if($isDefaultSpacePublic)checked#end value="true">
										<span>$!lang.get("onboarding.publicsite")</span>
									</label>
								</p>
								<div class="switch">
									<label>
										<input type="checkbox" name="darkMode" class="filled-in" value="true">
										<span>#icon('<path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" />' '')
										$!lang.get('settings.darkmode.text')</span>
									</label>
								</div>
							</div>
							<hr />
							<div class="card z-depth-0 pal mtl">
								<h4 class="center mbl">$!lang.get("onboarding.admin")</h4>

								<div class="input-field mtm">
									<label for="admin-name">$!lang.get('name')</label>
									<input type="text" id="admin-name" name="adminName" maxlength="255" value="$!adminName">
								</div>
								<div class="input-field pbl">
									<label for="admin-email">$!lang.get('onboarding.admin.email')</label>
									<input type="email" id="admin-email" name="adminEmail" class="validate" value="$!adminEmail">
									<span>$!lang.get("onboarding.admin.email.hint")</span>
								</div>

								<div class="input-field">
									<select name="authMethod" id="auth-method-select">
										<option value="password" #if($passwordAuthEnabled)selected#end>$!lang.get('password')</option>
										<option value="google">Google</option>
										<option value="facebook">Facebook</option>
										<option value="microsoft">Microsoft</option>
									</select>
									<label>$!lang.get("onboarding.auth.method")</label>
								</div>

								<div id="auth-password-fields">
									<div class="input-field mvm">
										<label for="passw">$!lang.get('password')</label>
										<input id="passw" type="password" name="adminPassword" value="" minlength="$MIN_PASS_LENGTH">
										<div><small id="pass-meter-message" class="grey-text"></small></div>
									</div>
								</div>

								<div id="auth-social-fields" class="hide">
									<div id="social-google-fields" class="hide">
										<div class="lightborder pas mvl">
											<ol>
												<li> $!lang.get('onboarding.auth.hint1')</li>
												<li> $!lang.get('onboarding.auth.hint2') </br> <small><code>$!paraEndpoint/google_auth</code></small></li>
												<li> $!lang.get('onboarding.auth.hint3')</li>
											</ol>
										</div>
										<div class="input-field mtm">
											<label for="gp-app-id">Google Client ID</label>
											<input type="text" id="gp-app-id" name="gpAppId" value="$!gpAppId">
										</div>
										<div class="input-field mtm">
											<label for="gp-secret">Google Client Secret</label>
											<input type="password" id="gp-secret" name="gpSecret" value="$!gpSecret">
										</div>
									</div>
									<div id="social-facebook-fields" class="hide">
										<div class="lightborder pas mvl">
											<ol>
													<li> $!lang.get('onboarding.auth.hint1')</li>
													<li> $!lang.get('onboarding.auth.hint2') </br> <small><code>$!paraEndpoint/facebook_auth</code></small></li>
													<li> $!lang.get('onboarding.auth.hint3')</li>
											</ol>
										</div>
										<div class="input-field mtm">
											<label for="fb-app-id">Facebook App ID</label>
											<input type="text" id="fb-app-id" name="fbAppId" value="$!fbAppId">
										</div>
										<div class="input-field mtm">
											<label for="fb-secret">Facebook App Secret</label>
											<input type="password" id="fb-secret" name="fbSecret" value="$!fbSecret">
										</div>
									</div>
									<div id="social-microsoft-fields" class="hide">
										<div class="lightborder pas mvl">
											<ol>
													<li> $!lang.get('onboarding.auth.hint1')</li>
													<li> $!lang.get('onboarding.auth.hint2') </br> <small><code>$!paraEndpoint/microsoft_auth</code></small></li>
													<li> $!lang.get('onboarding.auth.hint3')</li>
											</ol>
										</div>
										<div class="input-field mtm">
											<label for="ms-app-id">Microsoft Application ID</label>
											<input type="text" id="ms-app-id" name="msAppId" value="$!msAppId">
										</div>
										<div class="input-field mtm">
											<label for="ms-secret">Microsoft Client Secret</label>
											<input type="password" id="ms-secret" name="msSecret" value="$!msSecret">
										</div>
										<div class="input-field mtm">
											<label for="ms-tenant">Microsoft Tenant ID</label>
											<input type="password" id="ms-tenant" name="msTenant" value="$!msTenant">
										</div>
									</div>

									<p class="mtm">
										<label>
											<input type="checkbox" name="redirectToIdp" class="filled-in" #if($redirectToIdp)checked#end value="true">
											<span>$!lang.get("onboarding.auth.redirect")</span>
										</label>
									</p>
								</div>

								<div class="center pvl">
									<button class="lightborder btn-flat waves-effect waves-light" type="submit">
										$!lang.get('next') &rarr;
									</button>
								</div>
							</div>
						</form>
					</div>
				</div>
			</div>
			#end
			#if ($step == 4)
			<div class="card-panel mvl">
				<div class="card z-depth-0 pal mtl">
					<h3 class="center">$!lang.get("onboarding.smtp")</h3>
					<p class="center">$!lang.get("onboarding.smtp.hint")</p>

					<form method="post" action="$onboardinglink/smtp-setup" id="onboarding-smtp-form">
						<div id="smtp-fields">
							<div class="input-field mtl">
								<label for="mail-host">$!lang.get("onboarding.smtp.host")</label>
								<input type="text" id="mail-host" name="mailHost" value="$mailHost">
							</div>
							<div class="input-field mtm">
								<label for="mail-port">$!lang.get("onboarding.smtp.port")</label>
								<input type="number" id="mail-port" name="mailPort" value="587" value="$mailPort">
							</div>
							<div class="input-field mtm">
								<label for="mail-username">$!lang.get("onboarding.smtp.username")</label>
								<input type="text" id="mail-username" name="mailUsername" value="$mailUsername">
							</div>
							<div class="input-field mtm">
								<label for="mail-password">$!lang.get("onboarding.smtp.password")</label>
								<input type="password" id="mail-password" name="mailPassword" value="$mailPassword">
							</div>
							<p class="mtm center">
								<label class="mhs">
									<input type="checkbox" name="mailTLS" class="filled-in" #if($mailTls)checked value="true"#end>
									<span>TLS</span>
								</label>
								<label class="mhs">
									<input type="checkbox" name="mailSSL" class="filled-in" #if($mailSsl)checked value="true"#end>
									<span>SSL</span>
								</label>
							</p>
							<div class="center mtl">
								<button type="button" id="test-smtp-btn" class="btn-flat waves-effect" data-url="$onboardinglink/test-smtp-connection">
									$!lang.get("onboarding.testconnection")
								</button>
								<div id="smtp-test-result" class="mtm">&nbsp;
									#if ($smtpConfigured)
										<span class="green-text text-darken-3 center mvl pvl">
											#ico("check-circle" "") $!lang.get("onboarding.smtp.configured")
										</span>
									#end
								</div>
							</div>
						</div>
						<div class="center pvl">
							<button class="lightborder btn-flat waves-effect waves-light" type="submit" name="skipSmtp" value="false">
								$!lang.get("onboarding.finish")
							</button>
						</div>
					</form>
				</div>
			</div>
			#end
		</div>
	</div>
</div>

<style>
.logo-bg {
	position: absolute;
	top: 0;
	left: 0;
	height: 250px;
	width: 100%;
	background-image: url("data:image/svg+xml;base64,");
}
.inset-gradient {
	inset: 0px;
	height: 100%;
