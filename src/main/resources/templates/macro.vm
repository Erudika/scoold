#macro(paginate $macroCode $pager $_rpath $pageparam)
#if($pager && $pager.count > 0)
	#if ($pager.page <= 1)
		#set($prev = 1)
	#else
		#set($prev = $pager.page - 1)
	#end
	#if(!$_rpath || $_rpath.isEmpty() || $_rpath.startsWith("#"))
		#set($hashSuffix = "$!_rpath" )
		#if($request.queryString)
			#set($_rpath = "$!{request.requestURI}?$!{request.queryString}")
		#else
			#set($_rpath = "$!{request.requestURI}")
		#end
	#end
	#set($rexp = "${pageparam}=(\d+|&amp;)+")
	#set($_rpath = $_rpath.replaceAll($rexp, ""))
	#set($_rpath = $_rpath.replaceAll("(&amp;|&|\?)$", ""))
	<div class="page-content">#evaluate($scooldUtils.getMacroCode($macroCode))</div>
	#if ($_rpath.contains("?"))#set($paramseparator = "&")#else #set($paramseparator = "?")#end
	#if ($pager.count > $pager.limit && $macroCode && !$macroCode.trim().isEmpty())
		<div class="pages center mvm pvm">
			#if($numericPaginationEnabled && $macroCode != "postcomments")
				#set($maxPageLinks = 7)
				#set($activeClass = "active light-blue")
				#set($pageCount = ($pager.count / $pager.limit))
				#if($pager.count % $pager.limit > 0) #set($pageCount = $pageCount + 1) #end
				#if($pageCount > $MAX_PAGES)#set($pageCount = $MAX_PAGES)#end
				#if ($pager.page >= $pageCount) #set($next = 1) #else #set($next = $pager.page + 1) #end
				<ul class="pagination ptl">
					<li><a href="${_rpath}${paramseparator}${pageparam}=$!prev$!hashSuffix"><span class="grey-text">◀</span></a></li>
					#if($pager.page <= $maxPageLinks)
						#set($startPage = 1)
						#if($pageCount < $maxPageLinks)#set($endPage = $pageCount)#else#set($endPage = $maxPageLinks)#end
						#foreach($page in [$startPage..$endPage])
							#if($page == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
							<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=$!page$!hashSuffix">$!page</a></li>
						#end
						#if($pageCount > $maxPageLinks)
							<span class="pvm phm">…</span>
							#if($pageCount == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
							<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=$pageCount$!hashSuffix">$pageCount</a></li>
						#end
					#elseif($pager.page > $maxPageLinks && $pager.page < ($pageCount - $maxPageLinks))
						#set($startPage = $pager.page - ($maxPageLinks / 2))
						#set($endPage = $pager.page + ($maxPageLinks / 2))
						#if(1 == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
						<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=1$!hashSuffix">1</a></li>
						<span class="pvm phm">…</span>
						#foreach($page in [$startPage..$endPage])
							#if($page == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
							<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=$!page$!hashSuffix">$!page</a></li>
						#end
						<span class="pvm phm">…</span>
						#if($pageCount == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
						<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=$pageCount$!hashSuffix">$pageCount</a></li>
					#else
						#if(1 == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
						<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=1$!hashSuffix">1</a></li>
						<span class="pvm phm">…</span>
						#set($startPage = $pageCount - $maxPageLinks)
						#set($endPage = $pageCount)
						#foreach($page in [$startPage..$endPage])
							#if($page == $pager.page)#set($currPage = $activeClass)#else#set($currPage = "")#end
							<li class="waves-effect ${currPage}"><a href="${_rpath}${paramseparator}${pageparam}=$!page$!hashSuffix">$!page</a></li>
						#end
					#end
					<li><a href="${_rpath}${paramseparator}${pageparam}=$!next$!hashSuffix"><span class="grey-text">▶</span></a></li>
				</ul>
			#else
				#set($next = $pager.page + 1)
				<a href="${_rpath}${paramseparator}${pageparam}=$!next" class="more-link pagelink chip" title="Load more">$!lang.get("more")</a>
				<span class="hide page-macro-code">$!macroCode</span>
				<span class="$!{next}"></span>
			#end
		</div>
	#end
#end
#end
