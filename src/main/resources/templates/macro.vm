#macro(smallpersonbox $showu)
#if($showu)#set($userboxid = "$!{showu.id}")#else#set($userboxid = "")#end
<div class="row mbn userbox user-${userboxid}">
	<div class="col s4 m5 l3">
		#if ($showu)
			<a href="$!showu.getProfileLink()" title="$!showu.name">
				<img src="#profilepic($!showu, 'Square50')" width="50" class="profile-pic responsive-img" alt="pic">
			</a>
		#else
			<img src="$!imageslink/anon.svg" width="50" class="responsive-img" alt="pic">
		#end
	</div>
	<div class="col s8 m7 l9">
		<div class="right">
			#if($showu && $showu.id)
				#set($contextboxid = $utils.generateSecurityToken(10, true))
				<a class="dropdown-trigger grey-text text-darken-2" href="#" data-target="$contextboxid" title="More">
					⠿<span class="hide">More</span></a>
				<ul id="${contextboxid}" class="dropdown-content">
					<li>#getreportlink($showu "$profilelink/$!showu.id" "")</li>
				</ul>
			#end
		</div>
		<div class="userbox-body">
			#if ($showu)
				<a href="$!showu.getProfileLink()" class="userbox-name">$showu.name</a>
			#else
