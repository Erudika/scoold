#macro(newcommentform $parentid $hidden $uri)
#if ($hidden) #set($hide = "hide") #else	#set($hide = "") #end
<div class="newcommentform mtm ${hide}">
	<form method="post" action="$commentlink" class="new-comment-form">
		##sectoken(false "ADD_COMMENT_$!parentid") ## BREAKS AJAX - NOT USED
		<div class="row mbn">
			<div class="col s10">
				<div class="input-field mvn">
					#set($maxplus1 = $!maxCommentLength + 1)
					<label for="new-comment-$!{parentid}">$!lang.get('comment.title')
						<span class="grey-text mhs">#ico("info-circle" "") $!lang.get('comments.markdown'), e.g.
						<span>[link](http://url.com)</span> <code>`code`</code> <b>**bold**</b> <i>*italic*</i></small>
					</label>
					<input id="new-comment-$!{parentid}" type="text" name="comment" value=""
								 data-length="$!maxCommentLength" maxlength="$!maxplus1" class="validate charcounter" required>
					<span class="helper-text" data-error="$!maxCommentLengthError"></span>
				</div>
				<input type="hidden" name="parentid" value="$!parentid">
			</div>
			<div class="col s2 center">
				<button type="submit" class="btn waves-effect waves-light new-comment-btn">$!lang.get('add')</button>
			</div>
		</div>
	</form>
</div>
#end
