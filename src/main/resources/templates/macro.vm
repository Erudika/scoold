#macro(spacebox $space)
<div class="col s12 m6 l3 spacebox">
	<div class="card-panel z-depth-0 lightborder">
		<div class="row mbn viewbox valign-wrapper">
			<div class="col s12 m11 columns ">
				#if($isDefaultSpacePublic && $scooldUtils.isDefaultSpace($space.name))
				<span class="tooltipped" data-tooltip="This space is public">#ico("unlock" "green-text")</span>
				#else
				<span class="tooltipped" data-tooltip="This space is private">#ico("lock" "grey-text")</span>
				#end
				#if($scooldUtils.isDefaultSpace($space.name))
					#set($spaceName = $!lang.get('defaultspace'))
				#else
					#set($spaceName = $!space.name)
				#end
				#if($scooldUtils.isAutoAssignedSpace($space))
					<span class="grey-text tooltipped" data-tooltip="Assigned to all users">
						#icon('<path d="M19 17V19H7V17S7 13 13 13 19 17 19 17M16 8A3 3 0 1 0 13 11A3 3 0 0 0 16 8M19.2 13.06A5.6 5.6 0 0 1 21 17V19H24V17S24 13.55 19.2 13.06M18 5A2.91 2.91 0 0 0 17.11 5.14A5 5 0 0 1 17.11 10.86A2.91 2.91 0 0 0 18 11A3 3 0 0 0 18 5M7.34 8.92L8.5 10.33L3.75 15.08L1 12.08L2.16 10.92L3.75 12.5L7.34 8.92" />' '')
					</span>
				#end
				<a href="$questionslink/space/$!space.id" class="space-name-box" title="$!{spaceName}">$!{spaceName}</a>
			</div>
			<div class="col s12 m1 columns right-align">
				#if(!$scooldUtils.isDefaultSpace($space.name))
				<a href="#" title="$!lang.get('edit')" class="editlink">#ico("pencil" "orange-text")</a>
				#end
			</div>
		</div>
		#if(!$scooldUtils.isDefaultSpace($space.name))
		<div class="row mbn hide editbox">
			<form method="post" action="$adminlink/rename-space" class="space-rename-form">
				<div class="">
					<div class="input-field">
						<label for="new-space-${space.id}">$!lang.get('name')</label>
						<input type="text" id="new-space-${space.id}" name="newspace" class="validate" value="$!space.name" required>
						<input type="hidden" name="space" class="validate" value="$!space.id">
					</div>
				</div>
				<div class="">
					<div class="mbm smallText">
						<label>
							<input type="checkbox" name="assigntoall" class="filled-in"
										 #if($scooldUtils.isAutoAssignedSpace($space))checked="checked"#end
										 #if($scooldUtils.isAutoAssignedSpaceInConfig($space))disabled#end>
							<span>$!lang.get('assignspacetoall')</span>
						</label>
					</div>
					<div class="mbm smallText">
						<label>
							<input type="checkbox" name="needsapproval" class="filled-in"
										 #if($space.getProperties().getOrDefault("posts_need_approval", $scooldUtils.config.postsNeedApproval()))checked="checked"#end>
							<span>$!lang.get('admin.needapproval')</span>
						</label>
					</div>
					<a href="$adminlink/remove-space?space=$!space.id:$!space.name"
						 class="red-text right mts delete-space">$!lang.get('delete')</a>
					<button class="btn waves-effect waves-light" type="submit">$!lang.get('save')</button>
				</div>
			</form>
		</div>
		#end
	</div>
</div>
#end
