#macro(webhookbox $webhook )
<div class="col s12 webhookbox">
	<div class="card-panel">
		<a href="$adminlink/delete-webhook?id=$!webhook.id" class="red-text right tooltipped pts delete-webhook"
			 data-tooltip="$!lang.get('delete')">#ico("close" "")</a>
		<div class="mediumText">
			#if($webhook.active)#set($showActiveWebhook = "")#else #set($showActiveWebhook = "hide")#end
			#if(!$webhook.active)#set($showInactiveWebhook = "")#else #set($showInactiveWebhook = "hide")#end
			<a href="$adminlink/toggle-webhook?id=$!webhook.id" class="tooltipped toggle-webhook ${showActiveWebhook}" data-tooltip="Deactivate"><span class="green-text">⏺</span></a>
			<a href="$adminlink/toggle-webhook?id=$!webhook.id" class="tooltipped toggle-webhook ${showInactiveWebhook}" data-tooltip="Activate"><span class="red-text">⏺</span></a>
			<span class="mrm">$!webhook.targetUrl</span>
			#if($webhook.create)
				<code class="chip">create</code>
			#end
			#if($webhook.update)
				<code class="chip">update</code>
			#end
			#if($webhook.delete)
				<code class="chip">delete</code>
			#end
			#if($webhook.createAll)
				<code class="chip">createAll</code>
			#end
			#if($webhook.updateAll)
				<code class="chip">updateAll</code>
			#end
			#if($webhook.deleteAll)
				<code class="chip">deleteAll</code>
			#end
			#if($webhook.typeFilter)
				<code class="chip">#ico("filter" "grey-text") $!webhook.typeFilter</code>
			#end
			#if($webhook.propertyFilter)
				<code class="chip">#ico("filter" "grey-text") $!webhook.propertyFilter</code>
			#end
			#foreach($event in $webhook.customEvents)
				<code class="chip">$!event</code>
			#end
			#if(!$webhook.urlEncoded)
				<code class="chip" title="application/json">{JSON}</code>
			#end
			<span class="chip">
				<a href="#" class="permalink" data-value="$!webhook.secret" title="Copy verification key">
					#icon('<path d="M7 14C5.9 14 5 13.1 5 12S5.9 10 7 10 9 10.9 9 12 8.1 14 7 14M12.6 10C11.8 7.7 9.6 6 7 6C3.7 6 1 8.7 1 12S3.7 18 7 18C9.6 18 11.8 16.3 12.6 14H16V18H20V14H23V10H12.6Z" />' '')
				</a>
			</span>
			#if($webhook.tooManyFailures)
				<div class="red-text">
					#ico("exclamation-circle" "") Webhook was disabled due to too many failed delivery attempts.
				</div>
			#end
		</div>
	</div>
</div>
#end
